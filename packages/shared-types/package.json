{
  "name": "@cushion-saas/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for Cushion SaaS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    // building with `-b` is harmless here and keeps the pattern
    // consistent across all packages. it also generates the tsbuildinfo
    // that TypeScript uses to validate referenced consumers.
    "build": "tsc -b",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0"
  }
}
