// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  SUPER_ADMIN
  RETAILER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

model User {
  id       String     @id @default(cuid())
  email    String     @unique
  password String // Hashed with bcrypt
  role     UserRole
  status   UserStatus @default(PENDING)

  // Profile
  firstName String?
  lastName  String?
  phone     String?

  // Retailer-specific (null for admin)
  retailerId String?   @unique
  retailer   Retailer? @relation(fields: [retailerId], references: [id])

  // Invitation system
  invitationToken   String?   @unique
  invitationExpires DateTime?
  invitedById       String?
  invitedBy         User?     @relation("UserInvitations", fields: [invitedById], references: [id])
  invitationsSent   User[]    @relation("UserInvitations")

  // Notifications
  notifications Notification[]

  // Timestamps
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete

  @@index([email])
  @@index([role])
  @@index([retailerId])
  @@index([invitationToken])
  @@map("users")
}

// ==================== RETAILER ====================

enum BrandPreference {
  ALWAYS
  PER_ORDER
  NONE
}

enum ShippingPreference {
  SHIP_TO_RETAILER
  DROP_SHIP
}

enum RetailerStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum MarkupType {
  PERCENTAGE
  FIXED
}

model Retailer {
  id           String  @id @default(cuid())
  businessName String
  contactName  String
  email        String  @unique
  phone        String?

  // Address stored as JSON
  address Json? // { line1, line2, city, state, zip, country }

  // Branding
  logoUrl        String?
  primaryColor   String? @default("#3b82f6")
  secondaryColor String? @default("#1e40af")

  // Markup settings
  markupType  MarkupType @default(PERCENTAGE)
  markupValue Decimal    @default(0) @db.Decimal(10, 2) // % or fixed amount

  // Brand Settings
  labelPreference BrandPreference? @default(NONE)
  labelTitle      String?
  labelStyle      String?
  labelPlacement  String?
  labelFileUrl    String?
  labelCost       Decimal?         @default(8.00) @db.Decimal(10, 2)

  pdfPreference    BrandPreference? @default(NONE)
  pdfCustomization Json?
  pdfCost          Decimal?         @default(10.00) @db.Decimal(10, 2)

  shippingPreference ShippingPreference? @default(SHIP_TO_RETAILER)

  // Status
  status RetailerStatus @default(ACTIVE)

  // Relations
  user                  User?
  calculatorAssignments RetailerCalculatorAssignment[]
  quotes                Quote[]
  orders                Order[]

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  @@index([status])
  @@index([email])
  @@map("retailers")
}

// ==================== CALCULATOR SYSTEM ====================

enum CalculatorStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Calculator {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Configuration stored as JSON
  config Json // CalculatorConfig type

  // Status
  status   CalculatorStatus @default(DRAFT)
  version  Int              @default(1)
  isMaster Boolean          @default(false)
  parentId String? // For versioning

  fabricBrands FabricBrand[]

  // Relations
  assignments RetailerCalculatorAssignment[]
  createdById String

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  @@index([status])
  @@index([isMaster])
  @@map("calculators")
}

enum AssignmentType {
  SYNCED // Updates propagate from master
  DETACHED // Independent copy
}

model RetailerCalculatorAssignment {
  id String @id @default(cuid())

  // Relations
  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  calculatorId String
  calculator   Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  // Assignment type
  assignmentType AssignmentType @default(SYNCED)

  // Custom pricing (if DETACHED)
  customPricing Json? // Override base prices

  // Timestamps
  assignedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([retailerId, calculatorId])
  @@index([retailerId])
  @@index([calculatorId])
  @@map("retailer_calculator_assignments")
}

// ==================== FABRIC MANAGEMENT ====================

enum FabricPriceTier {
  TIER_1 // $21.89375
  TIER_2 // $24.0125
  TIER_3 // $25.425
  TIER_4 // $33.90
  TIER_5 // $36.725
  TIER_6 // $73.45
}

model FabricBrand {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Relations
  calculatorId String
  calculator   Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  fabrics      Fabric[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([calculatorId])
  @@map("fabric_brands")
}

model Fabric {
  id          String  @id @default(cuid())
  name        String
  code        String // Internal code like "SOLID_3737_ARDOISE"
  description String?
  imageUrl    String

  // Pricing
  price     Decimal         @default(0) @db.Decimal(10, 2)
  priceTier FabricPriceTier @default(TIER_1)

  // Relations
  brandId String
  brand   FabricBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([code])
  @@map("fabrics")
}

// ==================== QUOTE SYSTEM ====================

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CONVERTED
}

enum PaymentStatus {
  PENDING
  UNPAID // kept for backwards compatibility with existing DB rows
  SUCCESS
  FAILED
  REFUNDED
}

model Quote {
  id          String @id @default(cuid())
  quoteNumber String @unique // Generated: QUO-2024-XXXX

  // Relations
  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id])

  // Customer info
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress Json? // { line1, line2, city, state, zip }

  // Preferences explicitly for this quote (snapshotted at creation)
  labelPreference    BrandPreference?
  labelFileUrl       String?  // Snapshot of retailer label image at quote creation
  labelTitle         String?  // Snapshot of retailer label title at quote creation
  pdfPreference      BrandPreference?
  shippingPreference ShippingPreference?

  isCustomized        Boolean   @default(false)
  customizationSentAt DateTime?
  pdfCustomization    Json?

  // Quote data
  items QuoteItem[]

  // Pricing
  subtotal     Decimal @db.Decimal(10, 2)
  markupAmount Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  // Status
  status QuoteStatus @default(DRAFT)

  // PDF
  pdfUrl String?

  // Expiration
  expiresAt DateTime?

  // Timestamps
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  convertedToOrderId String?  @unique

  // Payment tracking
  paymentStatus         PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  paymentDate           DateTime?

  @@index([retailerId])
  @@index([status])
  @@index([createdAt])
  @@index([quoteNumber])
  @@map("quotes")
}

model QuoteItem {
  id String @id @default(cuid())

  // Relations
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  // Selections
  productType    String
  shape          String // "Rectangle", "Round", etc.
  dimensions     Json // { length, width, thickness, diameter, ear, bottomWidth, topWidth }
  foamType       String // "High Density Foam", "Dry Fast Foam", "Fiber Fill", "Covers Only"
  fabricId       String?
  fabricCode     String // Denormalized for history
  fabricName     String?
  zipperPosition String // "Long Side", "Short Side", "No Zipper"
  piping         String // "Piping", "No Piping"
  ties           String // "No ties", "2 Side", "4 Side", "4 Corner"

  // Calculated values
  fabricMeters Decimal @db.Decimal(10, 4)
  quantity     Int     @default(1)

  // Costs (base costs - hidden from retailer)
  baseSewingCost    Decimal @db.Decimal(10, 2)
  baseFiberfillCost Decimal @db.Decimal(10, 2)
  basePipingCost    Decimal @db.Decimal(10, 2)
  baseTiesCost      Decimal @db.Decimal(10, 2)
  baseFabricCost    Decimal @db.Decimal(10, 2)
  baseSubtotal      Decimal @db.Decimal(10, 2)

  // Final pricing (with markup)
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Instructions
  instructions   String?
  attachmentUrls String[]

  // 3D Preview snapshot
  preview3DUrl String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_items")
}

// ==================== ORDER SYSTEM ====================

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY_FOR_SHIPPING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductionStatus {
  PENDING
  CUTTING
  SEWING
  FILLING
  QUALITY_CHECK
  COMPLETE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // ORD-2024-XXXX

  // Relations
  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id])
  quoteId    String?  @unique

  // Customer info (denormalized from quote)
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress Json?

  // Retailer preferences locked in at order
  labelPreference    BrandPreference?
  pdfPreference      BrandPreference?
  shippingPreference ShippingPreference?

  // Order items
  items OrderItem[]

  // Pricing
  subtotal     Decimal @db.Decimal(10, 2)
  markupAmount Decimal @db.Decimal(10, 2)
  total        Decimal @db.Decimal(10, 2)

  // Status workflow
  status   OrderStatus @default(PENDING)
  priority Priority    @default(NORMAL)

  // Production
  productionNotes String?

  // Shipping
  shippingAddress Json?
  trackingNumber  String?
  shippedAt       DateTime?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([retailerId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Copied from QuoteItem
  productType    String
  shape          String
  dimensions     Json
  foamType       String
  fabricCode     String
  zipperPosition String
  piping         String
  ties           String
  fabricMeters   Decimal  @db.Decimal(10, 4)
  quantity       Int
  unitPrice      Decimal  @db.Decimal(10, 2)
  totalPrice     Decimal  @db.Decimal(10, 2)
  instructions   String?
  attachmentUrls String[]

  // Production status
  productionStatus ProductionStatus @default(PENDING)
  productionNotes  String?
  assignedTo       String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([orderId])
  @@index([productionStatus])
  @@map("order_items")
}

// ==================== ASSET MANAGEMENT ====================

enum AssetCategory {
  SHAPE_IMAGE
  FOAM_IMAGE
  ZIPPER_IMAGE
  PIPING_IMAGE
  TIES_IMAGE
  FABRIC_IMAGE
  LOGO
  DOCUMENT
  OTHER
}

model Asset {
  id           String @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int // bytes
  url          String

  // Categorization
  category AssetCategory
  tags     String[]

  // Metadata
  metadata Json? // { width, height, etc. }

  // Uploader
  uploadedById String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([tags])
  @@map("assets")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // "QUOTE_CREATED", "ORDER_STATUS_CHANGED", etc.
  entityType String // "Quote", "Order", "Retailer"
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   String
  message String
  link    String?
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ==================== SYSTEM SETTINGS ====================

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json // E.g., { autoApproveQuotes: true }

  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
