{
  "name": "@cushion-saas/calculator-engine",
  "version": "1.0.0",
  "description": "Core calculation engine for cushion pricing",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    // use the build mode which understands project references so that
    // dependencies like @cushion-saas/shared-types are automatically
    // compiled when the engine is built. this avoids TS6305 errors when
    // a consuming package hasn't been compiled yet.
    "build": "tsc -b",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@cushion-saas/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0"
  }
}
