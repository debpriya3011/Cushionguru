# ==========================================
# Cushion SaaS - Environment Configuration
# ==========================================

# Database
DATABASE_URL=""

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000" # e.g. http://localhost:3000 -> Should typically be https://your-domain.com in production
NEXTAUTH_SECRET="" # Generate one via `openssl rand -base64 32`

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="us-east-1"
AWS_S3_ENDPOINT=""  # Optional - for MinIO or other S3-compatible services

# Or Supabase Storage (alternative to AWS)
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_BUCKET="cushion-assets"

# Email Service (Resend recommended)
RESEND_API_KEY=""
EMAIL_FROM="noreply@cushionsaas.com"
EMAIL_FROM_NAME="Cushion Quoting System"

# App Configuration
MAX_RETAILERS="30"
DEFAULT_MARKUP_PERCENTAGE="20"
DEFAULT_MARKUP_TYPE="PERCENTAGE"

# Feature Flags
ENABLE_3D_PREVIEW="true"
ENABLE_FABRIC_HOVER="true"
ENABLE_PDF_GENERATION="true"

# Redis (for caching and sessions)
REDIS_URL="" # e.g. redis://localhost:6379

# Logging
LOG_LEVEL="info"

# Stripe 
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Environment 
NODE_ENV="development" # Set to "production" in live environment
